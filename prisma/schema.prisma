// Prisma schema for pvprospect — PRD §15.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationSource {
  map_click
  manual_coordinates
  browser_geolocation
  nominatim_search
  unknown
}

enum ProspectRunStatus {
  success
  partial
  needs_location_choice
  invalid_location
  provider_error
  failed
}

enum ProviderSource {
  pvgis
  pvwatts
}

enum ProviderStatus {
  success
  failed
  partial
  disabled
  timeout
  rate_limited
}

enum ModuleType {
  standard
  premium
  thinfilm
}

enum MountingType {
  free
  roof
}

/// One end-to-end prospect calculation: location + assumptions + result.
model ProspectRun {
  id                    String             @id @default(cuid())
  createdAt             DateTime           @default(now())
  createdBy             String?
  locationInput         String
  locationDisplayLabel  String?
  locationSource        LocationSource
  lat                   Float
  lon                   Float
  systemSizeKwp         Float
  lossPercent           Float
  tiltDegrees           Float
  uiAzimuthDegrees      Float
  pvgisAspectDegrees    Float
  moduleType            ModuleType
  mountingType          MountingType
  status                ProspectRunStatus
  annualKwh             Float?
  annualKwhPerKwp       Float?
  sourceDeltaPercent    Float?
  warningsJson          Json               @default("[]")
  sources               ProspectSourceResult[]

  @@index([createdAt])
  @@index([lat, lon])
}

/// One provider's result inside a ProspectRun.
model ProspectSourceResult {
  id                String         @id @default(cuid())
  prospectRunId     String
  prospectRun       ProspectRun    @relation(fields: [prospectRunId], references: [id], onDelete: Cascade)
  source            ProviderSource
  status            ProviderStatus
  annualKwh         Float?
  annualKwhPerKwp   Float?
  monthlyJson       Json           @default("[]")
  assumptionsJson   Json           @default("{}")
  metadataJson      Json           @default("{}")
  warningsJson      Json           @default("[]")
  rawResponseRef    String?
  createdAt         DateTime       @default(now())

  @@unique([prospectRunId, source])
  @@index([source, status])
}

/// Cached Nominatim (or other geocoder) responses.
model GeocodingCache {
  id              String   @id @default(cuid())
  provider        String   @default("nominatim")
  normalizedQuery String
  acceptLanguage  String   @default("en")
  resultJson      Json
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())
  expiresAt       DateTime

  @@unique([provider, normalizedQuery, acceptLanguage])
  @@index([expiresAt])
}

/// Singleton-ish settings table for runtime-tweakable defaults.
model ProspectSettings {
  id                       String       @id @default(cuid())
  defaultSystemSizeKwp     Float        @default(10)
  defaultLossPercent       Float        @default(14)
  defaultTiltDegrees       Float        @default(35)
  defaultUiAzimuthDegrees  Float        @default(180)
  defaultModuleType        ModuleType   @default(standard)
  defaultMountingType      MountingType @default(free)
  pvgisBaseUrl             String       @default("https://re.jrc.ec.europa.eu/api/v5_3")
  pvwattsBaseUrl           String       @default("https://developer.nlr.gov/api/pvwatts/v8.json")
  geocodingProvider        String       @default("nominatim")
  nominatimBaseUrl         String       @default("https://nominatim.openstreetmap.org")
  cacheTtlDays             Int          @default(30)
  updatedAt                DateTime     @updatedAt
}
