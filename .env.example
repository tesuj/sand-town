# Copy to .env.local for development.
# .env.local is gitignored. Never commit real secrets.

# PVWatts v8 API (https://developer.nrel.gov/signup/) — free, instant generation
PVWATTS_API_KEY=

# Nominatim usage policy requires a contact email in User-Agent
NOMINATIM_CONTACT_EMAIL=

# PostgreSQL connection string used by Prisma at runtime
# Local dev (via docker-compose): postgresql://pvprospect:pvprospect@localhost:5432/pvprospect
DATABASE_URL=

# Optional — defaults to https://re.jrc.ec.europa.eu/api/v5_3 if unset
# PVGIS_BASE_URL=

# Optional — defaults to https://nominatim.openstreetmap.org if unset
# NOMINATIM_BASE_URL=
